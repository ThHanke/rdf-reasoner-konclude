{
  "name": "rdf-reasoner-konclude",
  "version": "0.1.0",
  "description": "OWL-DL tableau reasoning via Konclude compiled to WebAssembly. Async TypeScript API — pass an N3.js Store, get inferred triples back. Uses RDF.js Quad types throughout.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": ["./dist/worker.js"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.node.mjs",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./wasm": "./dist/konclude.wasm"
  },
  "files": [
    "dist",
    "NOTICE",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "cp ts/worker-node.mjs dist/worker-node.mjs && cp ts/index.node.mjs dist/index.node.mjs",
    "test": "vitest run",
    "apply-patches": "bash scripts/apply-patches.sh",
    "bench": "node tests/bench/bench.mjs"
  },
  "peerDependencies": {
    "@rdfjs/types": ">=2.0",
    "n3": ">=1.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.21.1",
    "n3": "^1.22.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.0",
    "@types/node": "^20.0.0"
  },
  "license": "LGPL-3.0-or-later",
  "keywords": [
    "owl",
    "owl-dl",
    "rdf",
    "reasoner",
    "webassembly",
    "wasm",
    "rdfjs",
    "n3",
    "n3js",
    "store"
  ],
  "homepage": "https://github.com/ThHanke/rdf-reasoner-konclude#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThHanke/rdf-reasoner-konclude"
  },
  "publishConfig": {
    "access": "public"
  }
}
